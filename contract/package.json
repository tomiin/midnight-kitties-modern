{
  "name": "kitties-contract",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "compact": "compact compile +0.31.0 src/kitties.compact src/managed/kitties",
    "compact-fast": "compact compile --skip-zk +0.31.0 src/kitties.compact src/managed/kitties",
    "test": "vitest run",
    "test:compile": "npm run compact && vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "0.16.0",
    "pino": "9.7.0",
    "pino-pretty": "13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0"
  }
}
